# Copy this file to .env for local development:
#   cp .env.example .env
# Then fill in OPENSEARCH_ENDPOINT from:
#   cd ../terraform && terraform output -raw opensearch_endpoint

# ── Environment ──────────────────────────────────────────────────────────────
# Controls log format and OTel behaviour:
#   development → colored human-readable logs, OTel disabled (no sidecar locally)
#   production  → JSON logs, OTel exported to ADOT sidecar at OTLP_ENDPOINT
ENVIRONMENT=development

# ── AWS ───────────────────────────────────────────────────────────────────────
# Local dev: uses your ~/.aws/config profile
# On EKS: provided automatically via IRSA (no key/secret needed in pod)
AWS_PROFILE=dev
AWS_REGION=eu-central-1

# ── Bedrock Models ────────────────────────────────────────────────────────────
LLM_MODEL_ID=anthropic.claude-haiku-20240307-v1:0
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ── OpenSearch Serverless ─────────────────────────────────────────────────────
# Get this value after terraform apply:
#   cd ../terraform && terraform output -raw opensearch_endpoint
OPENSEARCH_ENDPOINT=https://<collection-id>.eu-central-1.aoss.amazonaws.com
OPENSEARCH_INDEX=agent-chunks

# ── Observability ─────────────────────────────────────────────────────────────
SERVICE_NAME=mlops-agent
# OTLP_ENDPOINT only active when ENVIRONMENT=production (ADOT sidecar on EKS)
OTLP_ENDPOINT=http://localhost:4317
